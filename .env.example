# 大淘客 API
DATETOKE_APP_KEY=your_app_key_here
DATETOKE_APP_SECRET=your_app_secret_here

# 微博开放平台
WEIBO_APP_KEY=your_weibo_app_key
WEIBO_APP_SECRET=your_weibo_app_secret
WEIBO_REDIRECT_URI=http://localhost:8000/api/weibo/callback

# AI 文案生成（推荐用 DeepSeek）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# AI 配图生成（智谱 CogView-4，每天免费100张）
ZHIPU_API_KEY=your_zhipu_api_key

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/taoke.db

# 定时任务
DEFAULT_FETCH_INTERVAL_HOURS=6
DEFAULT_POST_INTERVAL_HOURS=2

# 养号
NURTURE_DEFAULT_INTERVAL_MINUTES=30
NURTURE_MAX_POSTS_PER_DAY=5
NURTURE_AI_MODEL=claude-opus-4-7
NURTURE_ENABLE_IMAGE=true
